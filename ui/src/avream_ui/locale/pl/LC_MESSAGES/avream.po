msgstr "Status punktu końcowego: połączono ({endpoint})"

msgid "Endpoint status: {endpoint} — {state}"
msgstr "Status punktu końcowego: {endpoint} — {state}"

msgid "Endpoint status: {endpoint} not found"
msgstr "Status punktu końcowego: {endpoint} nie znaleziono"

msgid "Clipboard unavailable"
msgstr "Schowek niedostępny"

msgid "No active display. Could not copy logs."
msgstr "Brak aktywnego wyświetlacza. Nie można skopiować logów."

msgid "Saved settings were reset to defaults."
msgstr "Zapisane ustawienia zostały przywrócone do domyślnych."

msgid "Reset saved UI settings"
msgstr "Resetuj zapisane ustawienia UI"

msgid "This removes saved UI settings and restores defaults. Continue?"
msgstr "Spowoduje to usunięcie zapisanych ustawień UI i przywrócenie domyślnych. Kontynuować?"

msgid "OK"
msgstr "OK"

msgid "Cancel"
msgstr "Anuluj"

msgid "Proceed"
msgstr "Kontynuuj"

msgid "Language changed. Restart AVream to apply."
msgstr "Język zmieniony. Uruchom AVream ponownie, aby zastosować."

msgid "Disconnect"
msgstr "Rozłącz"

msgid "Disconnect Wi-Fi endpoint from AVream session."
msgstr "Rozłącz punkt końcowy Wi-Fi z sesji AVream."

msgid "Connect selected Wi-Fi device or manual endpoint."
msgstr "Połącz wybrane urządzenie Wi-Fi lub ręczny punkt końcowy."

msgid "Stop stream and disconnect selected phone from AVream session."
msgstr "Zatrzymaj strumień i rozłącz wybrany telefon z sesji AVream."

msgid "Mark selected USB phone as active for streaming."
msgstr "Oznacz wybrany telefon USB jako aktywny do streamowania."

msgid "Scanning devices..."
msgstr "Skanowanie urządzeń..."

msgid "No phones detected. Connect USB phone and click Scan."
msgstr "Nie wykryto telefonów. Podłącz telefon USB i kliknij Skanuj."

msgid "Select a phone to connect (USB or Wi-Fi)."
msgstr "Wybierz telefon do połączenia (USB lub Wi-Fi)."

msgid "Active source: {serial} ({mode})"
msgstr "Aktywne źródło: {serial} ({mode})"

msgid "Phone is unauthorized. Unlock phone and accept the USB debugging prompt."
msgstr "Telefon jest nieautoryzowany. Odblokuj telefon i zaakceptuj monit debugowania USB."

msgid "Phone state: {state}. Try reconnecting USB."
msgstr "Stan telefonu: {state}. Spróbuj ponownie podłączyć USB."

msgid "Phone is ready ({transport}). Click Connect."
msgstr "Telefon jest gotowy ({transport}). Kliknij Połącz."

msgid "Connecting Wi-Fi endpoint..."
msgstr "Łączenie z punktem końcowym Wi-Fi..."

msgid "No phone selected"
msgstr "Nie wybrano telefonu"

msgid "Scan phones and select a device first."
msgstr "Najpierw zeskanuj telefony i wybierz urządzenie."

msgid "Phone not ready"
msgstr "Telefon nie jest gotowy"

msgid "Unlock phone and ensure it shows as 'device' in the list."
msgstr "Odblokuj telefon i upewnij się, że widnieje jako 'urządzenie' na liście."

msgid "Setting up Wi-Fi from selected USB phone..."
msgstr "Konfigurowanie Wi-Fi z wybranego telefonu USB..."

msgid "Wi-Fi ready: {endpoint}. You can disconnect USB and start camera in Stream."
msgstr "Wi-Fi gotowe: {endpoint}. Możesz odłączyć USB i uruchomić kamerę w zakładce Strumień."

msgid "Selecting Wi-Fi phone and reconnecting endpoint..."
msgstr "Wybieranie telefonu Wi-Fi i ponowne łączenie z punktem końcowym..."

msgid "Wi-Fi device connected: {endpoint}. Open Stream tab to start camera."
msgstr "Urządzenie Wi-Fi połączone: {endpoint}. Otwórz zakładkę Strumień, aby uruchomić kamerę."

msgid "USB mode selected"
msgstr "Wybrany tryb USB"

msgid "Selected phone is Wi-Fi. Either switch connection mode to Wi-Fi or select a USB device."
msgstr "Wybrany telefon jest Wi-Fi. Przełącz tryb połączenia na Wi-Fi lub wybierz urządzenie USB."

msgid "Phone selected and connected. Open Stream tab to start camera."
msgstr "Telefon wybrany i połączony. Otwórz zakładkę Strumień, aby uruchomić kamerę."

msgid "Preparing Wi-Fi connection..."
msgstr "Przygotowywanie połączenia Wi-Fi..."

msgid "Wi-Fi ready: {endpoint}. Starting camera..."
msgstr "Wi-Fi gotowe: {endpoint}. Uruchamianie kamery..."

msgid "Starting phone camera..."
msgstr "Uruchamianie kamery telefonu..."

msgid "Active source: {conn_type} — {serial}"
msgstr "Aktywne źródło: {conn_type} — {serial}"

msgid "Disconnecting Wi-Fi endpoint..."
msgstr "Rozłączanie punktu końcowego Wi-Fi..."

msgid "Disconnecting selected phone..."
msgstr "Rozłączanie wybranego telefonu..."

msgid "Phone disconnected from AVream session."
msgstr "Telefon rozłączony z sesji AVream."

msgid "Apply language change"
msgstr "Zastosuj zmianę języka"

msgid "Restart"
msgstr "Uruchom ponownie"

msgid "Restarts the application to apply the selected language."
msgstr "Uruchamia ponownie aplikację, aby zastosować wybrany język."

msgid "Keyboard shortcuts"
msgstr "Skróty klawiszowe"

msgid "Assign keyboard shortcuts to AVream actions."
msgstr "Przypisz skróty klawiszowe do akcji AVream."

msgid "Toggle camera"
msgstr "Włącz/wyłącz kamerę"

msgid "Camera Toggle Shortcut"
msgstr "Skrót przełączania kamery"

msgid "Press a key combination to assign to camera toggle.\nPress Escape to cancel."
msgstr "Naciśnij kombinację klawiszy, aby przypisać do przełączania kamery.\nNaciśnij Escape, aby anulować."

msgid "Disabled"
msgstr "Wyłączony"
