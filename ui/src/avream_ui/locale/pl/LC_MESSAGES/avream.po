msgstr "Nie można przetworzyć wyniku statusu."

msgid "Passwordless status parse error."
msgstr "Błąd parsowania statusu bezhasłowego."

msgid "Passwordless helper actions are enabled (runner: pkexec)."
msgstr "Bezhasłowe akcje helpera są włączone (runner: pkexec)."

msgid "Passwordless is enabled, but the service needs to be restarted to take effect. Restart AVream from Settings → Service."
msgstr "Tryb bezhasłowy jest włączony, ale usługa wymaga restartu. Zrestartuj AVream z Ustawienia → Usługa."

msgid "Passwordless helper actions are disabled."
msgstr "Bezhasłowe akcje helpera są wyłączone."

msgid "Tool not found"
msgstr "Narzędzie nie znalezione"

msgid "avream-passwordless-setup is not installed."
msgstr "avream-passwordless-setup nie jest zainstalowane."

msgid "User unknown"
msgstr "Nieznany użytkownik"

msgid "pkexec missing"
msgstr "Brak pkexec"

msgid "Install policykit-1 (pkexec) to run this action from GUI."
msgstr "Zainstaluj policykit-1 (pkexec), aby uruchomić tę akcję z GUI."

msgid "Enabling passwordless helper actions..."
msgstr "Włączanie bezhasłowych akcji helpera..."

msgid "Enable failed"
msgstr "Włączenie nie powiodło się"

msgid "Passwordless enabled"
msgstr "Tryb bezhasłowy włączony"

msgid "Passwordless helper actions were enabled. Log out and log in again to refresh group membership."
msgstr "Bezhasłowe akcje helpera zostały włączone. Wyloguj się i zaloguj ponownie, aby odświeżyć członkostwo w grupie."

msgid "Enable passwordless mode"
msgstr "Włącz tryb bezhasłowy"

msgid "This allows your local active user session to run AVream helper actions without password prompt. Continue?"
msgstr "Pozwoli to bieżącej sesji użytkownika uruchamiać akcje helpera AVream bez monitu o hasło. Kontynuować?"

msgid "Disabling passwordless helper actions..."
msgstr "Wyłączanie bezhasłowych akcji helpera..."

msgid "Disable failed"
msgstr "Wyłączenie nie powiodło się"

msgid "Passwordless disabled"
msgstr "Tryb bezhasłowy wyłączony"

msgid "Passwordless helper actions were disabled."
msgstr "Bezhasłowe akcje helpera zostały wyłączone."

msgid "Disable passwordless mode"
msgstr "Wyłącz tryb bezhasłowy"

msgid "This restores password prompts for AVream helper actions. Continue?"
msgstr "Przywróci to monity o hasło dla akcji helpera AVream. Kontynuować?"

msgid "README not found"
msgstr "README nie znaleziono"

