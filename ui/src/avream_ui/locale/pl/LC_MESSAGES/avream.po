msgstr "Aktywne źródło: {source}"

msgid "not selected"
msgstr "nie wybrano"

msgid "Stop camera first to change preview window mode."
msgstr "Najpierw zatrzymaj kamerę, aby zmienić tryb okna podglądu."

msgid "Stop camera first to change rotation."
msgstr "Najpierw zatrzymaj kamerę, aby zmienić obrót."

msgid "Preview window: {mode} (locked while camera is running)"
msgstr "Okno podglądu: {mode} (zablokowane podczas działania kamery)"

msgid "Stop camera first to change preview window mode and rotation."
msgstr "Najpierw zatrzymaj kamerę, aby zmienić tryb okna podglądu i obrót."

msgid "Toggle to show or hide separate AVream Preview window on next camera start."
msgstr "Przełącz, aby pokazać lub ukryć osobne okno podglądu AVream przy następnym uruchomieniu kamery."

msgid "Select camera rotation for next camera start."
msgstr "Wybierz obrót kamery dla następnego uruchomienia kamery."

msgid "Preview window: {mode}"
msgstr "Okno podglądu: {mode}"

msgid "Manual setup commands"
msgstr "Ręczne komendy konfiguracji"

msgid "Service enabled. Waiting for daemon startup..."
msgstr "Usługa włączona. Oczekiwanie na uruchomienie daemona..."

msgid "Service was enabled, but daemon is still unreachable. Click Retry or use manual commands."
msgstr "Usługa została włączona, ale daemon jest nadal nieosiągalny. Kliknij Ponów lub użyj ręcznych komend."

msgid "Service enabled. Waiting for daemon startup... ({done}/{total})"
msgstr "Usługa włączona. Oczekiwanie na uruchomienie daemona... ({done}/{total})"

msgid "Enabling AVream daemon service..."
msgstr "Włączanie usługi AVream daemon..."

msgid "Enable service failed"
msgstr "Włączenie usługi nie powiodło się"

msgid "Could not enable the AVream service automatically.\n\n{stderr}\n\nClick 'Show manual commands' to view the setup steps."
msgstr "Nie można automatycznie włączyć usługi AVream.\n\n{stderr}\n\nKliknij 'Pokaż ręczne komendy', aby zobaczyć kroki konfiguracji."

msgid "Stopping camera..."
msgstr "Zatrzymywanie kamery..."

msgid "Resetting camera..."
msgstr "Resetowanie kamery..."

msgid "Reset camera"
msgstr "Resetuj kamerę"

msgid "This reloads the virtual camera device. Continue?"
msgstr "Spowoduje to przeładowanie wirtualnego urządzenia kamery. Kontynuować?"

msgid "Disable"
msgstr "Wyłącz"

msgid "Disable passwordless helper actions."
msgstr "Wyłącz bezhasłowe akcje helpera."

msgid "Enable"
msgstr "Włącz"

msgid "Enable passwordless helper actions."
msgstr "Włącz bezhasłowe akcje helpera."

msgid "Passwordless setup tool is not installed."
msgstr "Narzędzie konfiguracji bezhasłowej nie jest zainstalowane."

msgid "Cannot detect current username."
msgstr "Nie można wykryć bieżącej nazwy użytkownika."

msgid "Checking passwordless status..."
msgstr "Sprawdzanie statusu bezhasłowego..."

