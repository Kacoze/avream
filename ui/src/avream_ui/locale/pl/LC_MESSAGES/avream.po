msgstr "Dostępne jest nowsze wydanie."

msgid "You are up to date."
msgstr "Jesteś na bieżąco."

msgid "Close"
msgstr "Zamknij"

msgid "Open Release"
msgstr "Otwórz wydanie"

msgid "Install Update"
msgstr "Zainstaluj aktualizację"

msgid "Cannot change while streaming"
msgstr "Nie można zmienić podczas streamowania"

msgid "Stop camera first, then change Preview window mode and start camera again."
msgstr "Najpierw zatrzymaj kamerę, następnie zmień tryb okna podglądu i uruchom kamerę ponownie."

msgid "Endpoint status: {endpoint} unavailable"
msgstr "Status punktu końcowego: {endpoint} niedostępny"

