msgstr "غير محدد"

msgid "Stop camera first to change preview window mode."
msgstr "أوقف الكاميرا أولاً لتغيير وضع نافذة المعاينة."

msgid "Stop camera first to change rotation."
msgstr "أوقف الكاميرا أولاً لتغيير التدوير."

msgid "Preview window: {mode} (locked while camera is running)"
msgstr "نافذة المعاينة: {mode} (مقفلة أثناء تشغيل الكاميرا)"

msgid "Stop camera first to change preview window mode and rotation."
msgstr "أوقف الكاميرا أولاً لتغيير وضع نافذة المعاينة والتدوير."

msgid "Toggle to show or hide separate AVream Preview window on next camera start."
msgstr "قم بالتبديل لعرض أو إخفاء نافذة معاينة AVream المنفصلة عند بدء تشغيل الكاميرا."

msgid "Select camera rotation for next camera start."
msgstr "حدد تدوير الكاميرا لبدء تشغيل الكاميرا التالي."

msgid "Preview window: {mode}"
msgstr "نافذة المعاينة: {mode}"

msgid "Manual setup commands"
msgstr "أوامر الإعداد اليدوي"

msgid "Service enabled. Waiting for daemon startup..."
msgstr "تم تفعيل الخدمة. في انتظار بدء تشغيل الخدمة الخلفية..."

msgid "Service was enabled, but daemon is still unreachable. Click Retry or use manual commands."
msgstr "تم تفعيل الخدمة، لكن الخدمة الخلفية لا تزال غير قابلة للوصول. انقر على إعادة المحاولة أو استخدم الأوامر اليدوية."

msgid "Service enabled. Waiting for daemon startup... ({done}/{total})"
msgstr "تم تفعيل الخدمة. في انتظار بدء التشغيل... ({done}/{total})"

msgid "Enabling AVream daemon service..."
msgstr "جاري تفعيل خدمة AVream الخلفية..."

msgid "Enable service failed"
msgstr "فشل تفعيل الخدمة"

msgid "Could not enable the AVream service automatically.\n\n{stderr}\n\nClick 'Show manual commands' to view the setup steps."
msgstr "تعذر تفعيل خدمة AVream تلقائياً.\n\n{stderr}\n\nانقر على 'عرض الأوامر اليدوية' لعرض خطوات الإعداد."

msgid "Stopping camera..."
msgstr "جاري إيقاف الكاميرا..."

msgid "Resetting camera..."
msgstr "جاري إعادة تعيين الكاميرا..."

msgid "Reset camera"
msgstr "إعادة تعيين الكاميرا"

msgid "This reloads the virtual camera device. Continue?"
msgstr "سيعيد هذا تحميل جهاز الكاميرا الافتراضي. هل تريد المتابعة؟"

msgid "Disable"
msgstr "تعطيل"

msgid "Disable passwordless helper actions."
msgstr "تعطيل إجراءات المساعد بدون كلمة مرور."

msgid "Enable"
msgstr "تفعيل"

