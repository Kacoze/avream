msgstr "Wi-Fi جاهز: {endpoint}. يمكنك فصل USB وبدء الكاميرا في قسم البث."

msgid "Selecting Wi-Fi phone and reconnecting endpoint..."
msgstr "جاري تحديد هاتف Wi-Fi وإعادة الاتصال بنقطة النهاية..."

msgid "Wi-Fi device connected: {endpoint}. Open Stream tab to start camera."
msgstr "تم اتصال جهاز Wi-Fi: {endpoint}. افتح علامة تبويب البث لبدء الكاميرا."

msgid "USB mode selected"
msgstr "تم تحديد وضع USB"

msgid "Selected phone is Wi-Fi. Either switch connection mode to Wi-Fi or select a USB device."
msgstr "الهاتف المحدد يعمل بـ Wi-Fi. قم بتغيير وضع الاتصال إلى Wi-Fi أو حدد جهاز USB."

msgid "Phone selected and connected. Open Stream tab to start camera."
msgstr "تم تحديد الهاتف وتوصيله. افتح علامة تبويب البث لبدء الكاميرا."

msgid "Preparing Wi-Fi connection..."
msgstr "جاري تحضير اتصال Wi-Fi..."

msgid "Wi-Fi ready: {endpoint}. Starting camera..."
msgstr "Wi-Fi جاهز: {endpoint}. جاري بدء الكاميرا..."

msgid "Starting phone camera..."
msgstr "جاري بدء كاميرا الهاتف..."

msgid "Active source: {conn_type} — {serial}"
msgstr "المصدر النشط: {conn_type} — {serial}"

msgid "Disconnecting Wi-Fi endpoint..."
