msgid "Disconnecting selected phone..."
msgstr "جاري قطع اتصال الهاتف المحدد..."

msgid "Phone disconnected from AVream session."
msgstr "تم قطع اتصال الهاتف من جلسة AVream."

msgid "Apply language change"
msgstr "تطبيق تغيير اللغة"

msgid "Restart"
msgstr "إعادة التشغيل"

msgid "Restarts the application to apply the selected language."
msgstr "يعيد تشغيل التطبيق لتطبيق اللغة المحددة."

msgid "Keyboard shortcuts"
msgstr "اختصارات لوحة المفاتيح"

msgid "Assign keyboard shortcuts to AVream actions."
msgstr "تعيين اختصارات لوحة المفاتيح لإجراءات AVream."

msgid "Toggle camera"
msgstr "تبديل الكاميرا"

