msgstr "تم تغيير اللغة. أعد تشغيل AVream للتطبيق."

msgid "Disconnect"
msgstr "قطع الاتصال"

msgid "Disconnect Wi-Fi endpoint from AVream session."
msgstr "قطع اتصال نقطة نهاية Wi-Fi من جلسة AVream."

msgid "Connect selected Wi-Fi device or manual endpoint."
msgstr "اتصال بجهاز Wi-Fi المحدد أو نقطة النهاية اليدوية."

msgid "Stop stream and disconnect selected phone from AVream session."
msgstr "إيقاف البث وقطع اتصال الهاتف المحدد من جلسة AVream."

msgid "Mark selected USB phone as active for streaming."
msgstr "وضع علامة على هاتف USB المحدد كنشط للبث."

msgid "Scanning devices..."
msgstr "جاري البحث عن الأجهزة..."

msgid "No phones detected. Connect USB phone and click Scan."
msgstr "لم يتم اكتشاف هواتف. قم بتوصيل هاتف USB وانقر على البحث."

msgid "Select a phone to connect (USB or Wi-Fi)."
msgstr "اختر هاتفاً للاتصال (USB أو Wi-Fi)."

msgid "Active source: {serial} ({mode})"
msgstr "المصدر النشط: {serial} ({mode})"

msgid "Phone is unauthorized. Unlock phone and accept the USB debugging prompt."
msgstr "الهاتف غير مصرح له. افتح قفل الهاتف واقبل طلب تصحيح USB."

msgid "Phone state: {state}. Try reconnecting USB."
msgstr "حالة الهاتف: {state}. حاول إعادة توصيل USB."

msgid "Phone is ready ({transport}). Click Connect."
msgstr "الهاتف جاهز ({transport}). انقر على اتصال."

msgid "Connecting Wi-Fi endpoint..."
msgstr "جاري الاتصال بنقطة نهاية Wi-Fi..."

msgid "No phone selected"
msgstr "لم يتم تحديد هاتف"

